        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", app.Pid.ToString()); } catch { }
    }

    // ── LocalUser modal ────────────────────────────────────────────────────────

    private async Task OpenLocalUser(string id)
    {
        _localUserEditId  = id;
        _localUserLoading = true;
        _localUserError   = null;
        _localUserContent = string.Empty;
        _localUserPath    = string.Empty;
        _localUserExists  = false;
        var app = Scan.GetById(id);
        if (app is not null)
        {
            _localUserPath    = app.LocalUserPath;
            _localUserExists  = app.HasLocalUser;
            _localUserContent = app.HasLocalUser
                ? await File.ReadAllTextAsync(app.LocalUserPath)
                : "{\n  \n}";
        }
        _localUserLoading = false;
    }

    private void CloseLocalUser() => _localUserEditId = null;

    private async Task SaveLocalUser()
    {
        _localUserError  = null;
        _localUserSaving = true;
        try
        {
            JsonDocument.Parse(_localUserContent);
            await File.WriteAllTextAsync(_localUserPath, _localUserContent);
            _localUserEditId = null;
            await Task.Run(() => Scan.Scan());
            BuildAppList();
        }
        catch (JsonException ex) { _localUserError = "Ogiltig JSON: " + ex.Message; }
        catch (Exception ex)     { _localUserError = ex.Message; }
        finally                  { _localUserSaving = false; }
    }

    // ── Build ──────────────────────────────────────────────────────────────────

    private void LoadRepoProjects(string repoName)
    {
        var dir      = Path.Combine(Settings.Settings.RepoRootPath, repoName);
        var excluded = Settings.Settings.ExcludedProjects
            .Where(e => !string.IsNullOrWhiteSpace(e))
            .Select(e => e.Trim())
            .ToList();
        _repoProjects[repoName] = Directory.Exists(dir)
            ? [.. Directory.GetFiles(dir, "*.csproj", SearchOption.AllDirectories)
                .OrderBy(p => p)
                .Select(p => new ProjectInfo(Path.GetFileNameWithoutExtension(p), p))
                .Where(pi => !excluded.Any(e => pi.Name.Contains(e, StringComparison.OrdinalIgnoreCase)))]
            : [];
    }

    private BuildMode GetBuildMode(string repoName) =>
        _repoBuildFlags.TryGetValue(repoName, out var m) ? m : BuildMode.Ren;

    private void SetBuildMode(string repoName, BuildMode mode) =>
        _repoBuildFlags[repoName] = mode;

    private bool IsCsprojRunning(string csprojPath) =>
        _apps.Any(a => a.IsRunning &&
            string.Equals(Scan.GetById(a.Id)?.CsprojPath, csprojPath, StringComparison.OrdinalIgnoreCase));

    private Task BuildProject(string csprojPath, string repoName) =>
        BuildProjectCore(csprojPath, repoName);

    private async Task BuildAll(string repoName, BuildMode? modeOverride = null)
    {
        var repoDir = Path.Combine(Settings.Settings.RepoRootPath, repoName);
        var slnPath = FindSln(repoDir);
        if (slnPath is null) return;

        if (!_buildStates.TryGetValue(slnPath, out var state))
            _buildStates[slnPath] = state = new BuildState();
        if (state.IsBuilding) return;

        state.Lines.Clear();
        state.Status     = "";
        state.IsBuilding = true;
        state.Cts        = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);
        _expandedBuildOutputs.Add(slnPath);
        await InvokeAsync(StateHasChanged);

        var bm    = modeOverride ?? GetBuildMode(repoName);
        var flags = new BuildFlags
        {
            NoRestore   = bm == BuildMode.Snabb,
            NoAnalyzers = bm != BuildMode.Normal,
            NoDocs      = bm != BuildMode.Normal,
        };

        try
        {
            await Build.BuildAsync(
                [new RepoBuildTarget { RepoName = repoName, SlnPath = slnPath }],
                flags,
                onProgress:   (__, status) => { state.Status = status; _ = InvokeAsync(StateHasChanged); },
                onOutputLine: (__, line) =>
                {
                    state.Lines.Add(line);
                    if (state.Lines.Count > 500) state.Lines.RemoveAt(0);
                    _ = InvokeAsync(StateHasChanged);
                },
                state.Cts.Token);
        }
        catch (OperationCanceledException) { state.Status = "Avbruten"; }

        state.IsBuilding = false;
        _expandedBuildOutputs.Remove(slnPath);
        await InvokeAsync(StateHasChanged);
    }

    private static string? FindSln(string dir)
    {
        foreach (var pattern in new[] { "*.sln", "*.slnx" })
        {
            var f = Directory.GetFiles(dir, pattern, SearchOption.TopDirectoryOnly).FirstOrDefault()
                 ?? Directory.GetFiles(dir, pattern, SearchOption.AllDirectories).FirstOrDefault();
            if (f is not null) return f;
        }
        return null;
    }

    private async Task BuildProjectCore(string csprojPath, string repoName, BuildMode? modeOverride = null)
    {
        if (!_buildStates.TryGetValue(csprojPath, out var state))
            _buildStates[csprojPath] = state = new BuildState();
        if (state.IsBuilding) return;

        state.Lines.Clear();
        state.Status     = "";
        state.IsBuilding = true;
        state.Cts        = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);
        _expandedBuildRepos.Add(repoName);
        await InvokeAsync(StateHasChanged);

        var bm     = modeOverride ?? GetBuildMode(repoName);
        var target = new RepoBuildTarget
        {
            RepoName = Path.GetFileNameWithoutExtension(csprojPath),
            SlnPath  = csprojPath,
        };
        var flags = new BuildFlags
        {
            NoRestore   = bm == BuildMode.Snabb,
            NoAnalyzers = bm != BuildMode.Normal,
            NoDocs      = bm != BuildMode.Normal,
        };

        try
        {
            await Build.BuildAsync(
                [target], flags,
                onProgress:   (__, status) => { state.Status = status; _ = InvokeAsync(StateHasChanged); },
                onOutputLine: (__, line) =>
                {
                    state.Lines.Add(line);
                    if (state.Lines.Count > 500) state.Lines.RemoveAt(0);
                    _ = InvokeAsync(StateHasChanged);
                },
                state.Cts.Token);
        }
        catch (OperationCanceledException) { state.Status = "Avbruten"; }

        state.IsBuilding = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task BuildAllRepos()
    {
        _buildAllCts?.Dispose();
        _buildAllCts = CancellationTokenSource.CreateLinkedTokenSource(_cts.Token);
        var sem = new SemaphoreSlim(_globalMaxParallel);
        try
        {
            await Task.WhenAll(_groups.Select(async r =>
            {
                await sem.WaitAsync(_buildAllCts.Token);
                try   { await BuildAll(r, _globalBuildMode); }
                finally { sem.Release(); }
            }));
        }
        catch (OperationCanceledException) { }
    }

    private void CancelAllBuilds()
    {
        _buildAllCts?.Cancel();
        foreach (var s in _buildStates.Values)
            s.Cts?.Cancel();
    }

    private void ToggleBuildOutput(string csprojPath)
    {
        if (!_expandedBuildOutputs.Remove(csprojPath))
            _expandedBuildOutputs.Add(csprojPath);
    }

