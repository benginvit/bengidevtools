    private class AppViewModel
    {
        public required string Id            { get; set; }
        public required string RepoName      { get; set; }
        public required string ProjectName   { get; set; }
        public int?            HttpsPort     { get; set; }
        public string?         LaunchProfile { get; set; }
        public bool            IsRunning     { get; set; }
        public bool            HasLocalUser  { get; set; }
        public string          GitStatus     { get; set; } = "–";
        public string          GitBranch     { get; set; } = string.Empty;
        public bool            Checked       { get; set; } = true;
        public bool            HasException  { get; set; }
        public bool            IsExternal    { get; set; }
        public int             Pid           { get; set; } = -1;
    }

    private class ConsoleState : IDisposable
    {
        public List<string>            Lines  { get; } = new();
        public int                     Offset { get; set; }
        public CancellationTokenSource Cts    { get; } = new();
        public void Dispose() => Cts.Cancel();
    }

    private record ProjectInfo(string Name, string Path);

    private class BuildState
    {
        public bool                        IsBuilding { get; set; }
        public string                      Status     { get; set; } = "";
        public List<string>                Lines      { get; } = [];
        public CancellationTokenSource?    Cts        { get; set; }
    }

    private enum BuildMode { Snabb, Ren, Normal }
}
