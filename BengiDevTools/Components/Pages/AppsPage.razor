@page "/"
@inject AppScanService Scan
@inject IProcessService Proc
@inject IGitService Git
@inject ISettingsService Settings
@inject IBuildService Build
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="apps-page">
    <!-- ── Tre-kolumns header ── -->
    <div style="display:grid;grid-template-columns:2fr 1fr 150px;border-bottom:1px solid #333;flex-shrink:0">
        <!-- Launch header -->
        <div style="padding:6px 8px;border-right:1px solid #333;display:flex;flex-direction:column;gap:4px">
            <div style="display:flex;gap:4px;align-items:center">
                <button class="btn sm primary" @onclick="StartSelected"
                        disabled="@(_checkedCount == 0 || _starting || _stopping)">
                    @if (_starting) { <span class="status-spinner">⟳</span> } else { <text>▶</text> }
                    Starta (@_checkedCount)
                </button>
                <button class="btn sm danger" @onclick="StopAll" disabled="@(_stopping || _starting)">
                    @if (_stopping) { <span class="status-spinner">⟳</span> } else { <text>■</text> }
                    Stoppa alla
                </button>
                <div style="position:relative">
                    <button class="btn sm" @onclick="() => _showScanMenu = !_showScanMenu"
                            title="Scanna och exportera">•••</button>
                    @if (_showScanMenu)
                    {
                        <div style="position:absolute;top:calc(100% + 3px);left:0;z-index:50;background:#1e1e1e;border:1px solid #444;border-radius:3px;padding:3px;display:flex;flex-direction:column;gap:2px;min-width:170px">
                            <button class="btn sm" style="width:100%;text-align:left"
                                    @onclick="async () => { _showScanMenu = false; await DoScan(); }"
                                    disabled="@_scanning"
                                    title="@(_lastScanned.HasValue ? "Senast: " + _lastScanned.Value.ToLocalTime().ToString("g") : "Aldrig scannad")">
                                ⟳ Scanna
                                @if (_lastScanned.HasValue)
                                {
                                    <span style="color:var(--muted);font-size:9px;margin-left:4px">@_lastScanned.Value.ToLocalTime().ToString("d")</span>
                                }
                            </button>
                            <a class="btn sm" href="/api/apps/localuser/export" download="appsettings-localuser.zip"
                               @onclick="() => _showScanMenu = false"
                               style="width:100%;text-align:left;text-decoration:none">
                                ↓ Exportera localuser
                            </a>
                        </div>
                    }
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:6px;font-size:11px">
                <label class="cb">
                    <input type="checkbox" checked="@(_apps.Count > 0 && _apps.All(a => a.Checked))"
                           @onchange="ToggleAllChecked" />
                    <span style="color:var(--muted)">Välj alla</span>
                </label>
                <span style="color:var(--muted)">@_runningCount/@_apps.Count kör</span>
            </div>
        </div>
        <!-- Bygg header -->
        <div style="padding:6px 8px;border-right:1px solid #333;display:flex;align-items:center;gap:4px;flex-wrap:wrap">
            <button class="btn sm" @onclick="BuildAllRepos" disabled="@(_apps.Count == 0)">Bygg alla</button>
            <button class="btn sm @(_globalBuildMode == BuildMode.Snabb ? "primary" : "")"
                    title="Snabb: --no-restore, --no-analyzers, --no-docs"
                    @onclick="() => _globalBuildMode = BuildMode.Snabb">Snabb</button>
            <button class="btn sm @(_globalBuildMode == BuildMode.Ren ? "primary" : "")"
                    title="Ren: --no-restore, utan analyzers/docs"
                    @onclick="() => _globalBuildMode = BuildMode.Ren">Ren</button>
            <button class="btn sm @(_globalBuildMode == BuildMode.Normal ? "primary" : "")"
                    title="Normal: fullständigt bygge"
                    @onclick="() => _globalBuildMode = BuildMode.Normal">Normal</button>
            <select style="font-size:11px;background:var(--surface2);color:var(--text);border:1px solid #444;border-radius:4px;padding:2px 4px"
                    title="Max parallella byggen"
                    value="@_globalMaxParallel"
                    @onchange="e => _globalMaxParallel = int.Parse(e.Value!.ToString()!)">
                <option value="1">1 i taget</option>
                <option value="2">2 parallellt</option>
                <option value="3">3 parallellt</option>
                <option value="4">4 parallellt</option>
            </select>
            @if (_buildStates.Values.Any(s => s.IsBuilding))
            {
                <button class="btn sm danger" @onclick="CancelAllBuilds" title="Avbryt alla byggen">✕ Avbryt alla</button>
            }
            <button class="btn sm" @onclick="() => _expandedBuildRepos.Clear()"
                    title="Kollaps alla bygg-sektioner" disabled="@(_expandedBuildRepos.Count == 0)">▲ Kollaps</button>
        </div>
        <!-- Git header -->
        <div style="padding:6px 8px;display:flex;align-items:center">
            <button class="btn sm" @onclick="DoGitRefresh"
                    disabled="@(_gitLoading || _apps.Count == 0)"
                    title="Uppdatera git-status">
                @if (_gitLoading) { <span class="status-spinner">⟳</span> } else { <text>⟳</text> }
                Git
            </button>
        </div>
    </div>

    @if (_apps.Count == 0 && !_scanning)
    {
        <div style="color:var(--muted);font-size:12px;padding:8px">
            Tryck Scanna, eller kontrollera repo-rot i Inställningar.
        </div>
    }

    <!-- ── App list ── -->
    <div class="apps-list" style="flex:1;min-height:0">
        @foreach (var repoName in _groups)
        {
            var repoApps   = _apps.Where(a => a.RepoName == repoName).ToList();
            var gitStatus  = repoApps.FirstOrDefault()?.GitStatus ?? "–";
            var gitBranch  = repoApps.FirstOrDefault()?.GitBranch ?? string.Empty;
            var allChecked = repoApps.All(a => a.Checked);
            var nameColor  = gitStatus == "Uppdaterad" ? "var(--green)" : gitStatus == "Bakom" ? "var(--yellow)" : "var(--text)";
            var bm         = GetBuildMode(repoName);

            <div class="app-group" style="display:grid;grid-template-columns:2fr 1fr 150px;border-bottom:1px solid #222">

                <!-- ── Launch column ── -->
                <div style="border-right:1px solid #2a2a2a">
                    <div class="app-group-name">
                        <label class="cb" @onclick:stopPropagation>
                            <input type="checkbox" checked="@allChecked"
                                   @onchange="e => SetRepoChecked(repoName, (bool)(e.Value ?? false))" />
                        </label>
                        <span style="color:@nameColor">@repoName</span>
                    </div>
                    @foreach (var app in repoApps)
                    {
                        var isBusy     = _busyIds.Contains(app.Id);
                        var dotClass   = isBusy ? "starting" : app.HasException ? "exception" : app.IsExternal ? "external" : app.IsRunning ? "running" : "stopped";
                        var dotTitle   = isBusy          ? "Startar…" :
                                         app.HasException ? "Exception!" :
                                         app.IsExternal   ? "Externt startad" :
                                         app.IsRunning    ? $"PID {app.Pid} — klicka för att kopiera" : "Stoppad";
                        var isExpanded = _consoles.ContainsKey(app.Id);
                        var consoleId  = "con-" + app.Id.Replace('/', '-');

                        <div class="app-row @(isExpanded ? "app-row-selected" : "")"
                             style="cursor:pointer" @onclick="() => ToggleConsole(app.Id)">
                            <input type="checkbox" checked="@app.Checked"
                                   style="accent-color:var(--blue);width:13px;height:13px;cursor:pointer;flex-shrink:0"
                                   @onclick:stopPropagation
                                   @onchange="e => app.Checked = (bool)(e.Value ?? false)" />
                            <div class="app-dot @dotClass" title="@dotTitle"
                                 @onclick:stopPropagation @onclick="() => CopyPid(app)"></div>
                            <span class="app-name">@app.ProjectName</span>
                            <span class="app-port"
                                  style="@(app.HttpsPort.HasValue && app.IsRunning ? "cursor:pointer;color:var(--blue)" : "")"
                                  title="@(app.HttpsPort.HasValue && app.IsRunning ? $"Öppna https://localhost:{app.HttpsPort}" : "")"
                                  @onclick:stopPropagation
                                  @onclick="() => OpenPort(app)">@(app.HttpsPort.HasValue ? ":" + app.HttpsPort : string.Empty)</span>
                            <div class="app-actions" @onclick:stopPropagation>
                                <button class="btn sm"
                                        title="@(app.HasLocalUser ? "Redigera appsettings.localuser.json" : "Skapa appsettings.localuser.json")"
                                        style="opacity:@(app.HasLocalUser ? "1" : "0.4")"
                                        @onclick="() => OpenLocalUser(app.Id)">⚙</button>
                                @if (isBusy)
                                {
                                    <button class="btn sm primary" disabled><span class="status-spinner">⟳</span></button>
                                }
                                else if (!app.IsRunning)
                                {
                                    <button class="btn sm" @onclick="() => AppStart(app)">▶</button>
                                }
                                else
                                {
                                    <button class="btn sm" @onclick="() => AppRestart(app)">⟳</button>
                                    <button class="btn sm danger" @onclick="() => AppStop(app)">■</button>
                                }
                            </div>
                        </div>

                        @if (isExpanded && _consoles.TryGetValue(app.Id, out var con))
                        {
                            <div class="app-log-window">
                                <div class="debug-console-header">
                                    <span style="color:var(--blue);font-weight:600;font-size:11px">@app.ProjectName</span>
                                    <button class="btn sm" @onclick="() => ClearConsole(app.Id)">Rensa</button>
                                </div>
                                <div class="build-log" id="@consoleId">
                                    @if (con.Lines.Count == 0)
                                    {
                                        <span style="color:var(--muted)">Väntar på output...</span>
                                    }
                                    else
                                    {
                                        @foreach (var line in con.Lines)
                                        {
                                            <div style="color:@ColorLine(line)">@(string.IsNullOrEmpty(line) ? " " : line)</div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>

                <!-- ── Bygg column ── -->
                <div style="border-right:1px solid #2a2a2a">
                    @{ var repoExpanded = _expandedBuildRepos.Contains(repoName); }
                    @{ var slnDir = Path.Combine(Settings.Settings.RepoRootPath, repoName);
                       var slnKey = FindSln(slnDir) ?? "";
                       var slnBs  = slnKey != "" ? _buildStates.GetValueOrDefault(slnKey) : null;
                       var showSlnLog = slnKey != "" && _expandedBuildOutputs.Contains(slnKey); }
                    <div style="display:flex;gap:3px;padding:3px 6px;font-size:10px;background:#1a1a1a;border-bottom:1px solid #222;min-height:28px;align-items:center">
                        <button class="btn sm" title="Visa/dölj projekt"
                                @onclick="() => { if (!_expandedBuildRepos.Remove(repoName)) _expandedBuildRepos.Add(repoName); }">
                            @(repoExpanded ? "▲" : "▼")
                        </button>
                        <span style="color:#444;margin:0 1px">|</span>
                        <button class="btn sm @(bm == BuildMode.Snabb ? "primary" : "")"
                                title="Hoppar över restore, analyzers och docs – snabbast möjliga"
                                @onclick="() => SetBuildMode(repoName, BuildMode.Snabb)">Snabb</button>
                        <button class="btn sm @(bm == BuildMode.Ren ? "primary" : "")"
                                title="Med restore men hoppar över analyzers och docs"
                                @onclick="() => SetBuildMode(repoName, BuildMode.Ren)">Ren</button>
                        <button class="btn sm @(bm == BuildMode.Normal ? "primary" : "")"
                                title="Fullständigt bygge – alla steg aktiverade"
                                @onclick="() => SetBuildMode(repoName, BuildMode.Normal)">Normal</button>
                        <span style="color:#444;margin:0 1px">|</span>
                        <button class="btn sm" @onclick="() => BuildAll(repoName)">Bygg alla</button>
                        @if (slnBs is not null)
                        {
                            <span style="color:@(slnBs.Status == "OK" ? "var(--green)" : slnBs.Status == "FAILED" ? "var(--red)" : "var(--yellow)")">
                                @(slnBs.IsBuilding ? "⟳" : slnBs.Status == "OK" ? "✅" : slnBs.Status == "FAILED" ? "❌" : slnBs.Status)
                            </span>
                            <button class="btn sm" @onclick="() => ToggleBuildOutput(slnKey)">@(showSlnLog ? "▲" : "log")</button>
                            @if (slnBs.IsBuilding)
                            {
                                <button class="btn sm danger" @onclick="() => slnBs.Cts?.Cancel()" title="Avbryt bygge">✕</button>
                            }
                        }
                    </div>
                    @if (showSlnLog && slnBs is not null)
                    {
                        <div class="app-log-window" style="margin:0 4px 4px;max-height:200px">
                            <div class="build-log">
                                @foreach (var line in slnBs.Lines)
                                {
                                    <div style="color:@ColorLine(line)">@(string.IsNullOrEmpty(line) ? " " : line)</div>
                                }
                            </div>
                        </div>
                    }
                    @if (repoExpanded && _repoProjects.TryGetValue(repoName, out var projects))
                    {
                        @foreach (var proj in projects)
                        {
                            var bs         = _buildStates.GetValueOrDefault(proj.Path);
                            var showOutput = _expandedBuildOutputs.Contains(proj.Path);
                            var isRunning  = IsCsprojRunning(proj.Path);
                            var nc2        = isRunning              ? "var(--green)"
                                           : bs?.Status == "FAILED" ? "var(--red)"
                                           : bs?.Status == "OK"     ? "var(--green)"
                                           : "var(--muted)";
                            <div style="display:flex;align-items:center;gap:4px;padding:2px 6px;font-size:11px">
                                <button class="btn sm" disabled="@(bs?.IsBuilding == true || isRunning)"
                                        @onclick="() => BuildProject(proj.Path, repoName)">Bygg</button>
                                @if (bs?.IsBuilding == true)
                                {
                                    <span class="status-spinner" style="font-size:12px">⟳</span>
                                    <button class="btn sm danger" @onclick="() => bs.Cts?.Cancel()" title="Avbryt bygge">✕</button>
                                }
                                <span style="font-family:var(--mono);color:@nc2">@proj.Name</span>
                                @if (isRunning)
                                {
                                    <span style="color:var(--green);font-size:10px">● kör</span>
                                }
                                @if (bs is not null)
                                {
                                    <button class="btn sm" @onclick="() => ToggleBuildOutput(proj.Path)">
                                        @(showOutput ? "▲" : "▼")
                                    </button>
                                }
                            </div>
                            @if (showOutput && bs is not null)
                            {
                                <div class="app-log-window" style="margin:0 4px 4px;max-height:180px">
                                    <div class="debug-console-header">
                                        <span style="font-size:11px;color:var(--muted);font-family:var(--mono)">@proj.Name</span>
                                        <button class="btn sm" @onclick="() => { bs.Lines.Clear(); }">Rensa</button>
                                    </div>
                                    <div class="build-log">
                                        @foreach (var line in bs.Lines)
                                        {
                                            <div style="color:@ColorLine(line)">@(string.IsNullOrEmpty(line) ? " " : line)</div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    }
                </div>

                <!-- ── Git column ── -->
                <div style="padding:4px 6px;font-size:11px;min-height:28px">
                    @if (!string.IsNullOrEmpty(gitBranch))
                    {
                        <div style="font-family:var(--mono);color:var(--muted);font-size:10px">@gitBranch</div>
                    }
                    @if (gitStatus != "–")
                    {
                        <div style="color:@nameColor;font-size:10px">@gitStatus</div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- ── Status bar ── -->
@if (_statusLog.Count > 0)
{
    <div class="status-bar">
        <div class="status-bar-header">
            <span class="status-bar-title">
                @if (_statusBusy)
                {
                    <span class="status-spinner">⟳</span>
                }
                Status
            </span>
            <button class="btn sm" @onclick="() => _statusLog.Clear()">✕</button>
        </div>
        <div class="status-bar-log" id="status-log">
            @foreach (var entry in _statusLog)
            {
                <div style="color:@StatusColor(entry)">@entry</div>
            }
        </div>
    </div>
}

<!-- ── LocalUser modal ── -->
@if (_localUserEditId is not null)
{
    var luApp = _apps.FirstOrDefault(a => a.Id == _localUserEditId);
    <div class="modal-backdrop" @onclick="CloseLocalUser">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <div>
                    <div style="font-weight:600;color:var(--blue)">@(luApp?.ProjectName ?? _localUserEditId)</div>
                    <div style="font-size:10px;color:var(--muted);margin-top:2px">appsettings.localuser.json</div>
                    @if (!string.IsNullOrEmpty(_localUserPath))
                    {
                        <div style="font-size:10px;color:#555;margin-top:1px">@_localUserPath</div>
                    }
                </div>
                <div style="display:flex;gap:6px;align-items:center">
                    @if (!_localUserExists) { <span style="font-size:11px;color:var(--yellow)">Ny fil</span> }
                    <button class="btn sm primary" @onclick="SaveLocalUser"
                            disabled="@(_localUserSaving || _localUserLoading)">
                        @(_localUserSaving ? "..." : _localUserExists ? "Spara" : "Skapa")
                    </button>
                    <button class="btn sm" @onclick="CloseLocalUser">Avbryt</button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_localUserError))
            {
                <div style="padding:4px 12px;color:var(--red);font-size:11px">@_localUserError</div>
            }
            @if (_localUserLoading)
            {
                <div style="padding:16px;color:var(--muted);font-size:12px">Laddar...</div>
            }
            else
            {
                <textarea class="modal-editor" @bind="_localUserContent" @bind:event="oninput" spellcheck="false" />
            }
        </div>
    </div>
}

@code {
    // ── State ──────────────────────────────────────────────────────────────────

    private List<AppViewModel>       _apps       = [];
    private bool                     _scanning;
    private bool                     _gitLoading;
    private bool                     _starting;
    private bool                     _stopping;
    private DateTime?                _lastScanned;
    private readonly HashSet<string> _busyIds    = [];

    // Per-app consoles (keyed by app.Id)
    private readonly Dictionary<string, ConsoleState> _consoles = new();

    // Per-repo build
    private readonly HashSet<string>                        _expandedBuildOutputs = [];
    private readonly HashSet<string>                        _expandedBuildRepos   = [];
    private readonly Dictionary<string, List<ProjectInfo>> _repoProjects         = new();
    private readonly Dictionary<string, BuildState>        _buildStates          = new();
    private readonly Dictionary<string, BuildMode>          _repoBuildFlags       = new();
    private BuildMode                    _globalBuildMode   = BuildMode.Ren;
    private int                          _globalMaxParallel = 2;
    private CancellationTokenSource?     _buildAllCts;

    // LocalUser modal
    private string? _localUserEditId;
    private string  _localUserContent = string.Empty;
    private string  _localUserPath    = string.Empty;
    private bool    _localUserExists;
    private bool    _localUserLoading;
    private bool    _localUserSaving;
    private string? _localUserError;

    // Status log (sticky bottom bar)
    private readonly List<string> _statusLog = [];
    private bool                  _statusBusy;

    // Scan expand menu
    private bool _showScanMenu;

    private readonly CancellationTokenSource _cts = new();

    private IEnumerable<string> _groups => _apps
        .Select(a => a.RepoName).Distinct()
        .OrderBy(r => r.Contains("gateway", StringComparison.OrdinalIgnoreCase) ? 1 : 0)
        .ThenBy(r => r);
    private int _checkedCount => _apps.Count(a => a.Checked);
    private int _runningCount => _apps.Count(a => a.IsRunning);

    // ── Init / Dispose ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _lastScanned = Scan.LastScanned;
        BuildAppList();
        _ = PollLoop();
    }

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        foreach (var c in _consoles.Values) c.Dispose();
        await Task.CompletedTask;
    }

    // ── App list ───────────────────────────────────────────────────────────────

    private void BuildAppList()
    {
        var prev = _apps.ToDictionary(a => a.Id);
        _apps = Scan.Cached.Select(a => new AppViewModel
        {
            Id            = a.Id,
            RepoName      = a.RepoName,
            ProjectName   = a.ProjectName,
            HttpsPort     = a.HttpsPort,
            LaunchProfile = a.LaunchProfile,
            IsRunning     = Proc.IsRunning(a.Id),
            HasLocalUser  = a.HasLocalUser,
            GitStatus     = Scan.GetGitStatus(a.RepoName),
            GitBranch     = Scan.GetGitBranch(a.RepoName),
            Checked       = prev.TryGetValue(a.Id, out var p) ? p.Checked : true,
            HasException  = prev.TryGetValue(a.Id, out p) ? p.HasException : false,
            IsExternal    = false,
            Pid           = -1,
        }).ToList();

        foreach (var repoName in _apps.Select(a => a.RepoName).Distinct())
            LoadRepoProjects(repoName);
    }

    // ── Poll ───────────────────────────────────────────────────────────────────

    private async Task PollLoop()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        while (await timer.WaitForNextTickAsync(_cts.Token).ConfigureAwait(false))
        {
            try
            {
                await Proc.DetectExternalAsync(Scan.Cached);
                foreach (var app in _apps)
                {
                    app.IsRunning    = Proc.IsRunning(app.Id) || Proc.IsExternal(app.Id);
                    app.IsExternal   = Proc.IsExternal(app.Id);
                    app.Pid          = Proc.GetPid(app.Id);
                    app.HasException = Proc.HasException(app.Id);
                    app.GitStatus    = Scan.GetGitStatus(app.RepoName);
                    var b = Scan.GetGitBranch(app.RepoName);
                    if (!string.IsNullOrEmpty(b)) app.GitBranch = b;
                }
                await InvokeAsync(StateHasChanged);
            }
            catch (OperationCanceledException) { break; }
            catch { }
        }
    }

    // ── Status log helpers ─────────────────────────────────────────────────────

    private void StatusLog(string msg)
    {
        _statusLog.Add(msg);
        if (_statusLog.Count > 200) _statusLog.RemoveAt(0);
    }

    private async Task StatusLogAsync(string msg)
    {
        await InvokeAsync(() => { StatusLog(msg); StateHasChanged(); });
        try { await JS.InvokeVoidAsync("scrollToBottom", "status-log", _cts.Token); } catch { }
    }

    private static string StatusColor(string line)
    {
        if (line.StartsWith("──")) return "var(--muted)";
        if (line.Contains("Fel:") || line.Contains("saknas") || line.Contains("Okänd")) return "var(--red)";
        if (line.Contains("Bakom")) return "var(--yellow)";
        if (line.Contains("klar", StringComparison.OrdinalIgnoreCase)
            || line.Contains("Uppdaterad") || line.Contains("OK")) return "var(--green)";
        return "var(--text)";
    }

    // ── Scan ───────────────────────────────────────────────────────────────────

    private async Task DoScan()
    {
        _scanning   = true;
        _statusBusy = true;
        StatusLog("──── Scanna ────────────────────────────");
        await Task.Run(() => Scan.Scan(msg => _ = StatusLogAsync(msg)));
        BuildAppList();
        _lastScanned = Scan.LastScanned;
        _scanning    = false;
        await InvokeAsync(StateHasChanged);
        await DoCheckoutCore();
        await DoGitRefreshCore();
        _statusBusy = false;
        await InvokeAsync(StateHasChanged);
    }

    // ── Git ────────────────────────────────────────────────────────────────────

    private async Task DoGitRefresh()
    {
        _statusBusy = true;
        await DoGitRefreshCore();
        _statusBusy = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task DoGitRefreshCore()
    {
        _gitLoading = true;
        StatusLog("──── Git fetch & status ─────────────────");
        await InvokeAsync(StateHasChanged);

        var root  = Settings.Settings.RepoRootPath;
        var repos = _apps.Select(a => a.RepoName).Distinct().ToList();
        var sem   = new SemaphoreSlim(4);
        await Task.WhenAll(repos.Select(async repoName =>
        {
            await sem.WaitAsync(_cts.Token);
            try
            {
                var (status, branch) = await Git.GetStatusAsync(Path.Combine(root, repoName), _cts.Token);
                Scan.SetGitStatus(repoName, status, branch);
                foreach (var app in _apps.Where(a => a.RepoName == repoName))
                {
                    app.GitStatus = status;
                    if (!string.IsNullOrEmpty(branch)) app.GitBranch = branch;
                }
                var branchLabel = string.IsNullOrEmpty(branch) ? "" : $" [{branch}]";
                await StatusLogAsync($"  {repoName}{branchLabel}  →  {status}");
            }
            catch (OperationCanceledException) { }
            finally { sem.Release(); }
        }));

        _gitLoading = false;
        StatusLog("──── Git klar ───────────────────────────");
        await InvokeAsync(StateHasChanged);
    }

    private async Task DoCheckoutCore()
    {
        StatusLog("──── Checkout develop / pull ────────────");
        await InvokeAsync(StateHasChanged);

        var root  = Settings.Settings.RepoRootPath;
        var repos = _apps.Select(a => a.RepoName).Distinct().ToList();
        var sem   = new SemaphoreSlim(2);
        await Task.WhenAll(repos.Select(async repoName =>
        {
            await sem.WaitAsync(_cts.Token);
            try
            {
                var (branch, message) = await Git.CheckoutDefaultAndPullAsync(Path.Combine(root, repoName), _cts.Token);
                if (!string.IsNullOrEmpty(branch))
                    foreach (var app in _apps.Where(a => a.RepoName == repoName))
                        app.GitBranch = branch;
                var label = string.IsNullOrEmpty(branch) ? message : $"{branch}  {message}";
                await StatusLogAsync($"  {repoName}  →  {label}");
            }
            catch (OperationCanceledException) { }
            finally { sem.Release(); }
        }));

        StatusLog("──── Checkout klar ──────────────────────");
        await InvokeAsync(StateHasChanged);
    }

    // ── Checkbox helpers ───────────────────────────────────────────────────────

    private void ToggleAllChecked(ChangeEventArgs e) =>
        _apps.ForEach(a => a.Checked = (bool)(e.Value ?? false));

