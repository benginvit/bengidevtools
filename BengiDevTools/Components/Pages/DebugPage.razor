@page "/debug"
@inject ISettingsService Settings
@inject AppScanService Scan
@inject IProcessService Proc

<div class="debug-page">
    <div class="debug-layout">
        <!-- ── Sidebar ── -->
        <div class="debug-sidebar">
            <div style="display:flex;gap:4px;margin-bottom:8px">
                <button class="btn sm primary" @onclick="NewSqlJob" title="Nytt SQL-jobb">🗄 SQL</button>
                <button class="btn sm primary" @onclick="NewApiJob" title="Nytt API-jobb">⚡ API</button>
            </div>

            @if (_sqlJobs.Any())
            {
                <div class="debug-script-group">
                    <div class="debug-group-label">🗄 SQL</div>
                    @foreach (var job in _sqlJobs)
                    {
                        <div class="debug-script-row @(job.Id == _selected?.Id ? "selected" : "")"
                             @onclick="() => SelectJob(job)">
                            <span class="debug-script-name">@(string.IsNullOrEmpty(job.Name) ? "(namnlöst)" : job.Name)</span>
                            <button class="debug-run-btn" title="Kör"
                                    @onclick:stopPropagation @onclick="() => RunJobDirect(job)">▶</button>
                            <button class="debug-delete-btn" title="Ta bort"
                                    @onclick:stopPropagation @onclick="() => DeleteJob(job.Id)">✕</button>
                        </div>
                    }
                </div>
            }

            @if (_apiJobs.Any())
            {
                <div class="debug-script-group">
                    <div class="debug-group-label">⚡ API</div>
                    @foreach (var job in _apiJobs)
                    {
                        <div class="debug-script-row @(job.Id == _selected?.Id ? "selected" : "")"
                             @onclick="() => SelectJob(job)">
                            <span class="debug-method-badge" data-method="@job.Method">@job.Method</span>
                            <span class="debug-script-name">@(string.IsNullOrEmpty(job.Name) ? job.Url : job.Name)</span>
                            <button class="debug-run-btn" title="Kör"
                                    @onclick:stopPropagation @onclick="() => RunJobDirect(job)">▶</button>
                            <button class="debug-delete-btn" title="Ta bort"
                                    @onclick:stopPropagation @onclick="() => DeleteJob(job.Id)">✕</button>
                        </div>
                    }
                </div>
            }

            @if (!_sqlJobs.Any() && !_apiJobs.Any())
            {
                <div style="color:var(--muted);font-size:11px;padding:4px;line-height:1.6">
                    Skapa ett jobb med knapparna ovan.<br />
                    SQL = kör mot databasen.<br />
                    API = anrop mot en körande app.
                </div>
            }
        </div>

        <!-- ── Editor / Runner ── -->
        <div class="debug-editor-panel">
            @if (_form is not null)
            {
                <div class="scenario-form">
                    <!-- Header row -->
                    <div style="display:flex;align-items:center;gap:8px">
                        <span style="font-size:11px;color:var(--muted)">@(_form.Type == "sql" ? "🗄 SQL" : "⚡ API")</span>
                        <input class="input" style="flex:1" @bind="_form.Name" @bind:event="oninput"
                               placeholder="Namn på jobbet..." />
                        <button class="btn sm primary" disabled="@(_running || IsRunDisabled())" @onclick="RunJob">
                            @(_running ? "⟳" : "▶ Kör")
                        </button>
                        <button class="btn sm" disabled="@_saving" @onclick="SaveJob">
                            @(_saving ? "..." : "💾")
                        </button>
                        <button class="btn sm danger" @onclick="() => DeleteJob(_form.Id)" title="Ta bort">✕</button>
                    </div>

                    @if (_form.Type == "sql")
                    {
                        <textarea class="debug-sql-editor" style="flex:1;min-height:200px"
                                  @bind="_form.Sql" @bind:event="oninput"
                                  spellcheck="false" placeholder="-- Skriv SQL här..." />
                    }
                    else
                    {
                        <!-- App picker -->
                        <div class="scenario-row">
                            <label class="form-label" style="width:60px;flex-shrink:0">App</label>
                            <select class="input" @bind="_form.AppId" @bind:after="OnAppIdChanged">
                                <option value="">— välj körande app —</option>
                                @foreach (var a in _runningApps)
                                {
                                    <option value="@a.Id">@a.ProjectName :@a.HttpsPort</option>
                                }
                            </select>
                            <button class="btn sm" disabled="@(string.IsNullOrEmpty(_form.AppId) || _loadingSwagger)"
                                    @onclick="LoadSwagger">
                                @(_loadingSwagger ? "⟳" : "⚡ Swagger")
                            </button>
                        </div>

                        @if (_swagger.Count > 0)
                        {
                            <div class="scenario-row">
                                <label class="form-label" style="width:60px;flex-shrink:0">Endpoint</label>
                                <select class="input" @onchange="OnSwaggerEndpointSelected">
                                    <option value="">— välj endpoint —</option>
                                    @foreach (var ep in _swagger)
                                    {
                                        <option value="@(ep.Method + " " + ep.Path)">
                                            @ep.Method @ep.Path@(ep.Summary != null ? " — " + ep.Summary : "")@(ep.ExampleBody != null ? " ✦" : "")
                                        </option>
                                    }
                                </select>
                            </div>
                        }

                        <div class="scenario-row">
                            <select class="input" style="width:90px;flex-shrink:0" @bind="_form.Method">
                                @foreach (var m in new[] { "GET", "POST", "PUT", "PATCH", "DELETE" })
                                {
                                    <option value="@m">@m</option>
                                }
                            </select>
                            <input class="input" @bind="_form.Url" @bind:event="oninput"
                                   placeholder="https://localhost:7801/api/..." />
                        </div>

                        @if (!new[] { "GET", "HEAD" }.Contains(_form.Method))
                        {
                            <textarea class="debug-sql-editor" style="flex:1;min-height:120px"
                                      @bind="_form.Body" @bind:event="oninput"
                                      spellcheck="false" placeholder="{&#10;  &#10;}" />
                        }
                    }

                    @if (_sqlResult is not null)
                    {
                        <div class="sql-result @(_sqlResult.Success ? "" : "error")" style="flex-shrink:0">
                            @if (!_sqlResult.Success)
                            {
                                <span>❌ @_sqlResult.Error</span>
                            }
                            else
                            {
                                @foreach (var r in _sqlResult.Results ?? [])
                                {
                                    @if (r.Type == "nonquery")
                                    {
                                        <div class="sql-result-info">✅ @r.RowsAffected rad(er) påverkade</div>
                                    }
                                    else
                                    {
                                        <div class="sql-result-table-wrap">
                                            <table class="sql-table">
                                                <thead><tr>@foreach (var c in r.Columns) { <th>@c</th> }</tr></thead>
                                                <tbody>
                                                    @foreach (var row in r.Rows)
                                                    {
                                                        <tr>@foreach (var c in r.Columns) { <td>@(row.TryGetValue(c, out var v) ? v?.ToString() ?? "" : "")</td> }</tr>
                                                    }
                                                </tbody>
                                            </table>
                                            <div class="sql-result-info">@r.Rows.Count rad(er)</div>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    }

                    @if (_apiResult is not null)
                    {
                        <div class="sql-result @(_apiResult.Ok ? "" : "error")" style="flex-shrink:0">
                            <div class="sql-result-info">
                                <span style="color:@(_apiResult.Ok ? "var(--green)" : "var(--red)");font-weight:600">
                                    @_apiResult.Status @_apiResult.StatusText
                                </span>
                                <span style="margin-left:12px;color:var(--muted)">@_apiResult.Ms ms</span>
                            </div>
                            <pre class="sql-result-body">@_apiResult.Body</pre>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="color:var(--muted);font-size:12px;padding:20px;line-height:1.8">
                    Välj ett jobb i sidebaren eller skapa ett nytt.<br />
                    <span style="color:#555">▶</span> i listan kör jobbet direkt utan att öppna det.
                </div>
            }
        </div>
    </div>
</div>

@code {
    // ── State ──────────────────────────────────────────────────────────────────

    private List<Job>          _jobs       = [];
    private Job?               _selected;
    private Job?               _form;
    private List<SwaggerEp>    _swagger    = [];
    private bool               _loadingSwagger;
    private SqlQueryResult?    _sqlResult;
    private ApiCallResult?     _apiResult;
    private bool               _running;
    private bool               _saving;

    private List<RunningApp>   _runningApps = [];

    private IEnumerable<Job> _sqlJobs => _jobs.Where(j => j.Type == "sql");
    private IEnumerable<Job> _apiJobs => _jobs.Where(j => j.Type == "api");

    // ── Init ───────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadJobs();
        await Task.Run(() => Proc.DetectExternalAsync(Scan.Cached));
        _runningApps = Scan.Cached
            .Where(a => Proc.IsRunning(a.Id) && a.HttpsPort.HasValue)
            .Select(a => new RunningApp(a.Id, a.ProjectName, a.HttpsPort!.Value))
            .ToList();
    }

    // ── Jobs CRUD ──────────────────────────────────────────────────────────────

    private async Task LoadJobs() => _jobs = LoadScenarios().Select(ToJob).ToList();

    private void SelectJob(Job j)
    {
        _selected  = j;
        _form      = j.Clone();
        _sqlResult = null;
        _apiResult = null;
        _swagger   = [];
    }

    private void NewSqlJob() => OpenNew("sql");
    private void NewApiJob() => OpenNew("api");

    private void OpenNew(string type)
    {
        var j = new Job { Id = Guid.NewGuid().ToString(), Type = type };
        _selected  = j;
        _form      = j.Clone();
        _sqlResult = null;
        _apiResult = null;
        _swagger   = [];
    }

    private async Task SaveJob()
    {
        if (_form is null) return;
        _saving = true;
        if (string.IsNullOrEmpty(_form.Id)) _form.Id = Guid.NewGuid().ToString();
        var list = LoadScenarios();
        var s    = ToScenario(_form);
        var idx  = list.FindIndex(x => x.Id == s.Id);
        if (idx >= 0) list[idx] = s; else list.Add(s);
        SaveScenarios(list);
        await LoadJobs();
        _selected = ToJob(s);
        _form     = _selected.Clone();
        _saving   = false;
    }

    private async Task DeleteJob(string id)
    {
        if (string.IsNullOrEmpty(id)) return;
        var list = LoadScenarios().Where(x => x.Id != id).ToList();
        SaveScenarios(list);
        await LoadJobs();
        if (_selected?.Id == id) { _selected = null; _form = null; }
    }

    // ── Run ────────────────────────────────────────────────────────────────────

    private async Task RunJob()
    {
        if (_form is null) return;
        _running   = true;
        _sqlResult = null;
        _apiResult = null;
        if (_form.Type == "sql") await RunSql(_form.Sql);
        else                     await RunApi(_form.Method, _form.Url, _form.Body);
        _running = false;
    }

    private async Task RunJobDirect(Job j)
    {
        SelectJob(j);
        _running   = true;
        _sqlResult = null;
        _apiResult = null;
        StateHasChanged();
        if (j.Type == "sql") await RunSql(j.Sql);
        else                 await RunApi(j.Method, j.Url, j.Body);
        _running = false;
    }

    private async Task RunSql(string sql)
    {
        try
        {
            await using var conn = new Microsoft.Data.SqlClient.SqlConnection(Settings.Settings.SqlConnectionString);
            await conn.OpenAsync();

            var results = new List<SqlResultRow>();
            var batches = Regex.Split(sql, @"^\s*GO\s*$", RegexOptions.Multiline | RegexOptions.IgnoreCase)
                .Select(b => b.Trim()).Where(b => b.Length > 0);

            foreach (var batch in batches)
            {
                await using var cmd = new Microsoft.Data.SqlClient.SqlCommand(batch, conn);
                cmd.CommandTimeout = 60;

                if (batch.TrimStart().StartsWith("SELECT", StringComparison.OrdinalIgnoreCase))
                {
                    await using var reader = await cmd.ExecuteReaderAsync();
                    var cols = Enumerable.Range(0, reader.FieldCount).Select(i => reader.GetName(i)).ToList();
                    var rows = new List<Dictionary<string, object?>>();
                    while (await reader.ReadAsync())
                    {
                        var row = new Dictionary<string, object?>();
                        for (int i = 0; i < reader.FieldCount; i++)
                            row[cols[i]] = reader.IsDBNull(i) ? null : reader.GetValue(i);
                        rows.Add(row);
                    }
                    results.Add(new SqlResultRow("select", cols, rows, 0));
                }
                else
                {
                    var n = await cmd.ExecuteNonQueryAsync();
                    results.Add(new SqlResultRow("nonquery", [], [], n));
                }
            }
            _sqlResult = new SqlQueryResult(true, null, results);
        }
        catch (Exception ex)
        {
            _sqlResult = new SqlQueryResult(false, ex.Message, null);
        }
    }

    private async Task RunApi(string method, string url, string body)
    {
        var sw = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            using var http = new HttpClient(new HttpClientHandler
            {
                ServerCertificateCustomValidationCallback = (_, _, _, _) => true,
            });
            http.Timeout = TimeSpan.FromSeconds(30);
            var req = new HttpRequestMessage(new HttpMethod(method), url);
            if (!string.IsNullOrEmpty(body) && !new[] { "GET", "HEAD" }.Contains(method))
                req.Content = new StringContent(body, Encoding.UTF8, "application/json");
            var res  = await http.SendAsync(req);
            var text = await res.Content.ReadAsStringAsync();
            try { text = JsonSerializer.Serialize(JsonDocument.Parse(text).RootElement, new JsonSerializerOptions { WriteIndented = true }); } catch { }
            _apiResult = new ApiCallResult(res.IsSuccessStatusCode, (int)res.StatusCode, res.ReasonPhrase ?? string.Empty, text, sw.ElapsedMilliseconds);
        }
        catch (Exception ex)
        {
            _apiResult = new ApiCallResult(false, 0, "Nätverksfel", ex.Message, sw.ElapsedMilliseconds);
        }
    }

    // ── Swagger ────────────────────────────────────────────────────────────────

    private void OnAppIdChanged() => _swagger = [];

    private async Task LoadSwagger()
    {
        var app = _runningApps.FirstOrDefault(a => a.Id == _form?.AppId);
        if (app is null) return;
        _loadingSwagger = true;
        StateHasChanged();
        try
        {
            using var http = new HttpClient(new HttpClientHandler
            {
                ServerCertificateCustomValidationCallback = (_, _, _, _) => true,
            });
            http.Timeout = TimeSpan.FromSeconds(5);
            string[] urls =
            [
                $"https://localhost:{app.HttpsPort}/openapi/v1.json",
                $"https://localhost:{app.HttpsPort}/swagger/v1/swagger.json",
                $"https://localhost:{app.HttpsPort}/openapi/v1/openapi.json",
            ];
            JsonDocument? doc = null;
            foreach (var url in urls)
                try { doc = JsonDocument.Parse(await http.GetStringAsync(url)); break; } catch { }
            _swagger = doc is not null ? ParseSwagger(doc) : [];
        }
        finally { _loadingSwagger = false; }
    }

    private static List<SwaggerEp> ParseSwagger(JsonDocument doc)
    {
        var result = new List<SwaggerEp>();
        if (!doc.RootElement.TryGetProperty("paths", out var paths)) return result;
        foreach (var path in paths.EnumerateObject())
        {
            foreach (var op in path.Value.EnumerateObject())
            {
                var method = op.Name.ToUpperInvariant();
                if (!new[] { "GET", "POST", "PUT", "PATCH", "DELETE" }.Contains(method)) continue;
                var summary = op.Value.TryGetProperty("summary", out var s) ? s.GetString() : null;
                string? exampleBody = null;
                if (new[] { "POST", "PUT", "PATCH" }.Contains(method) &&
                    op.Value.TryGetProperty("requestBody", out var rb) &&
                    rb.TryGetProperty("content", out var content) &&
                    content.TryGetProperty("application/json", out var json))
                {
                    if (json.TryGetProperty("example", out var ex))
                        exampleBody = JsonSerializer.Serialize(ex, new JsonSerializerOptions { WriteIndented = true });
                    else if (json.TryGetProperty("schema", out var schema))
                        exampleBody = GenerateExample(schema, doc.RootElement, 0);
                }
                result.Add(new SwaggerEp(method, path.Name, summary, exampleBody));
            }
        }
        return [.. result.OrderBy(e => e.Path)];
    }

    private static string? GenerateExample(JsonElement schema, JsonElement root, int depth)
    {
        if (depth > 4) return null;
        if (schema.TryGetProperty("$ref", out var refEl))
        {
            var parts = refEl.GetString()?.TrimStart('#', '/').Split('/') ?? [];
            JsonElement node = root;
            foreach (var p in parts) if (!node.TryGetProperty(p, out node)) return null;
            return GenerateExample(node, root, depth + 1);
        }
        if (schema.TryGetProperty("example", out var ex)) return JsonSerializer.Serialize(ex);
        if (!schema.TryGetProperty("type", out var typeEl)) return null;
        return typeEl.GetString() switch
        {
            "object" when schema.TryGetProperty("properties", out var props) =>
                "{" + string.Join(",", props.EnumerateObject().Select(p =>
                    $"\"{p.Name}\":{GenerateExample(p.Value, root, depth + 1) ?? "null"}")) + "}",
            "string"           => "\"\"",
            "integer" or "number" => "0",
            "boolean"          => "false",
            "array" when schema.TryGetProperty("items", out var items) =>
                "[" + (GenerateExample(items, root, depth + 1) ?? "null") + "]",
            _ => null,
        };
    }

    private void OnSwaggerEndpointSelected(ChangeEventArgs e)
    {
        if (_form is null) return;
        var val = e.Value?.ToString();
        if (string.IsNullOrEmpty(val)) return;
        var ep = _swagger.FirstOrDefault(x => $"{x.Method} {x.Path}" == val);
        if (ep is null) return;
        var app   = _runningApps.FirstOrDefault(a => a.Id == _form.AppId);
        var base_ = app is not null ? $"https://localhost:{app.HttpsPort}" : string.Empty;
        _form.Method = ep.Method;
        _form.Url    = base_ + ep.Path;
        if (ep.ExampleBody is not null)
            try { _form.Body = JsonSerializer.Serialize(JsonDocument.Parse(ep.ExampleBody).RootElement, new JsonSerializerOptions { WriteIndented = true }); }
            catch { _form.Body = ep.ExampleBody; }
    }

    private bool IsRunDisabled() => _form is null ||
        (_form.Type == "sql" ? string.IsNullOrWhiteSpace(_form.Sql) : string.IsNullOrWhiteSpace(_form.Url));

    // ── Scenario persistence ───────────────────────────────────────────────────

    private string ScenariosFilePath => Path.Combine(Settings.Settings.DebugScriptsPath, "scenarios.json");

    private List<Scenario> LoadScenarios()
    {
        var path = ScenariosFilePath;
        if (!File.Exists(path)) return [];
        try { return JsonSerializer.Deserialize<List<Scenario>>(File.ReadAllText(path)) ?? []; }
        catch { return []; }
    }

    private void SaveScenarios(List<Scenario> list)
    {
        var dir = Settings.Settings.DebugScriptsPath;
        if (!string.IsNullOrEmpty(dir)) Directory.CreateDirectory(dir);
        File.WriteAllText(ScenariosFilePath, JsonSerializer.Serialize(list, new JsonSerializerOptions { WriteIndented = true }));
    }

    // ── Job ↔ Scenario mapping ─────────────────────────────────────────────────

    private static Job ToJob(Scenario s) => new()
    {
        Id     = s.Id,
        Name   = s.Name,
        Type   = s.Headers.TryGetValue("x-job-type", out var t) ? t : "api",
        Sql    = s.Headers.TryGetValue("x-sql",      out var q) ? q : string.Empty,
        AppId  = s.AppId,
        Method = s.Method,
        Url    = s.Url,
        Body   = s.Body,
    };

    private static Scenario ToScenario(Job j) => new()
    {
        Id      = string.IsNullOrEmpty(j.Id) ? Guid.NewGuid().ToString() : j.Id,
        Name    = j.Name,
        AppId   = j.AppId,
        Method  = j.Method,
        Url     = j.Url,
        Body    = j.Body,
        Headers = new Dictionary<string, string>
        {
            ["x-job-type"] = j.Type,
            ["x-sql"]      = j.Sql,
        },
    };

    // ── Model types ────────────────────────────────────────────────────────────

    private class Job
    {
        public string Id     { get; set; } = string.Empty;
        public string Name   { get; set; } = string.Empty;
        public string Type   { get; set; } = "sql";
        public string Sql    { get; set; } = string.Empty;
        public string AppId  { get; set; } = string.Empty;
        public string Method { get; set; } = "GET";
        public string Url    { get; set; } = string.Empty;
        public string Body   { get; set; } = string.Empty;
        public Job Clone() => (Job)MemberwiseClone();
    }

    private record RunningApp(string Id, string ProjectName, int HttpsPort);
    private record SwaggerEp(string Method, string Path, string? Summary, string? ExampleBody);
    private record SqlQueryResult(bool Success, string? Error, List<SqlResultRow>? Results);
    private record SqlResultRow(string Type, List<string> Columns, List<Dictionary<string, object?>> Rows, int RowsAffected);
    private record ApiCallResult(bool Ok, int Status, string StatusText, string Body, long Ms);
}
