<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BengiDevTools.ViewModels"
    xmlns:models="clr-namespace:BengiDevTools.Models"
    xmlns:conv="clr-namespace:BengiDevTools.Converters"
    x:DataType="vm:AppsViewModel"
    x:Class="BengiDevTools.Views.AppsPage"
    Title="Applikationer"
    BackgroundColor="{StaticResource PageBackgroundColor}">

    <ContentPage.Resources>
        <conv:BoolToColorConverter x:Key="BoolToColor" />
        <conv:GitStatusToColorConverter x:Key="GitStatusToColor" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">

        <!-- Header + global actions -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
            <Label
                Grid.Column="0"
                Text="Applikationer"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="{StaticResource SecondaryTextColor}"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Text="Starta alla"
                Command="{Binding StartAllCommand}"
                Style="{StaticResource SuccessButton}" />
            <Button
                Grid.Column="2"
                Text="Stoppa alla"
                Command="{Binding StopAllCommand}"
                Style="{StaticResource DangerButton}" />
            <Button
                Grid.Column="3"
                Text="Uppdatera git"
                Command="{Binding RefreshGitStatusCommand}"
                Style="{StaticResource SmallButton}" />
            <ActivityIndicator
                Grid.Column="4"
                IsRunning="{Binding IsRefreshingGit}"
                IsVisible="{Binding IsRefreshingGit}"
                WidthRequest="24"
                HeightRequest="24"
                VerticalOptions="Center" />
        </Grid>

        <!-- Groups + apps -->
        <ScrollView Grid.Row="1">
            <CollectionView ItemsSource="{Binding Groups}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AppGroup">
                        <VerticalStackLayout Spacing="4" Margin="0,0,0,16">

                            <!-- Group header -->
                            <Border
                                BackgroundColor="{StaticResource GroupHeaderColor}"
                                StrokeShape="RoundRectangle 4"
                                Padding="12,6">
                                <Label
                                    Text="{Binding Name}"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    TextColor="White" />
                            </Border>

                            <!-- Column headers -->
                            <Grid
                                ColumnDefinitions="16,*,160,100,Auto"
                                Padding="8,2"
                                ColumnSpacing="8">
                                <Label Grid.Column="1" Text="App" FontSize="11" TextColor="{StaticResource DisabledColor}" />
                                <Label Grid.Column="2" Text="URL" FontSize="11" TextColor="{StaticResource DisabledColor}" />
                                <Label Grid.Column="3" Text="Git" FontSize="11" TextColor="{StaticResource DisabledColor}" />
                                <Label Grid.Column="4" Text="Åtgärder" FontSize="11" TextColor="{StaticResource DisabledColor}" />
                            </Grid>

                            <!-- App rows -->
                            <CollectionView
                                ItemsSource="{Binding Apps}"
                                SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:AppDefinition">
                                        <Border
                                            BackgroundColor="{StaticResource SurfaceColor}"
                                            StrokeShape="RoundRectangle 4"
                                            Margin="0,1"
                                            Padding="8,6">
                                            <Grid
                                                ColumnDefinitions="16,*,160,100,Auto"
                                                ColumnSpacing="8"
                                                VerticalOptions="Center">

                                                <!-- Running indicator dot -->
                                                <Ellipse
                                                    Grid.Column="0"
                                                    WidthRequest="10"
                                                    HeightRequest="10"
                                                    Fill="{Binding IsRunning, Converter={StaticResource BoolToColor}}"
                                                    VerticalOptions="Center" />

                                                <!-- App name -->
                                                <Label
                                                    Grid.Column="1"
                                                    Text="{Binding Name}"
                                                    FontSize="13"
                                                    VerticalOptions="Center"
                                                    LineBreakMode="TailTruncation" />

                                                <!-- URL -->
                                                <Label
                                                    Grid.Column="2"
                                                    Text="{Binding LocalhostUrl}"
                                                    FontSize="11"
                                                    FontFamily="Consolas"
                                                    TextColor="{StaticResource DisabledColor}"
                                                    VerticalOptions="Center" />

                                                <!-- Git status -->
                                                <Label
                                                    Grid.Column="3"
                                                    Text="{Binding GitStatus}"
                                                    FontSize="11"
                                                    TextColor="{Binding GitStatus, Converter={StaticResource GitStatusToColor}}"
                                                    VerticalOptions="Center" />

                                                <!-- Actions -->
                                                <HorizontalStackLayout
                                                    Grid.Column="4"
                                                    Spacing="4">
                                                    <Button
                                                        Text="Starta"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AppsViewModel}}, Path=StartAppCommand}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SmallButton}"
                                                        IsEnabled="{Binding IsRunning, Converter={StaticResource InvertedBoolConverter}}" />
                                                    <Button
                                                        Text="Starta om"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AppsViewModel}}, Path=RestartAppCommand}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SmallButton}"
                                                        IsEnabled="{Binding IsRunning}" />
                                                    <Button
                                                        Text="Stoppa"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AppsViewModel}}, Path=StopAppCommand}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DangerButton}"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        IsEnabled="{Binding IsRunning}" />
                                                </HorizontalStackLayout>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <!-- Status bar -->
        <Border
            Grid.Row="2"
            BackgroundColor="{StaticResource SurfaceColor}"
            StrokeShape="RoundRectangle 4"
            Padding="12,6">
            <Label
                FontSize="12"
                TextColor="{StaticResource DisabledColor}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Igång: " />
                        <Span
                            Text="{Binding RunningCount}"
                            TextColor="{StaticResource SuccessColor}" />
                        <Span Text=" applikationer" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </Border>

    </Grid>
</ContentPage>
