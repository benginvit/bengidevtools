<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BengiDevTools.ViewModels"
    x:DataType="vm:SettingsViewModel"
    x:Class="BengiDevTools.Views.SettingsPage"
    Title="Inställningar"
    BackgroundColor="{StaticResource PageBackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" MaximumWidthRequest="600">

            <Label
                Text="Inställningar"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="{StaticResource SecondaryTextColor}"
                Margin="0,0,0,8" />

            <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderColor}" />

            <Label
                Text="Rot-katalog för repos"
                FontSize="14"
                TextColor="{StaticResource SecondaryTextColor}" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry
                    Grid.Column="0"
                    Text="{Binding RepoRootPath}"
                    Placeholder="C:\TFS\Repos"
                    FontFamily="Consolas"
                    FontSize="14" />
            </Grid>

            <Label
                Text="Standardvärde: C:\TFS\Repos"
                FontSize="11"
                TextColor="{StaticResource DisabledColor}" />

            <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderColor}" Margin="0,8" />

            <HorizontalStackLayout Spacing="8">
                <Button
                    Text="Spara"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource SuccessButton}"
                    WidthRequest="100" />
            </HorizontalStackLayout>

            <Label
                x:Name="SavedLabel"
                Text="Inställningar sparade!"
                TextColor="{StaticResource SuccessColor}"
                IsVisible="False" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
