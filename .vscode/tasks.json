{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-api",
      "type": "shell",
      "command": "dotnet build BengiDevTools.Api/BengiDevTools.Api.csproj",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "silent" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "npm-install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/BengiDevTools.Web" },
      "presentation": { "reveal": "always" }
    },
    {
      "label": "build-web",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/BengiDevTools.Web" },
      "dependsOn": ["build-api"],
      "presentation": { "reveal": "always" }
    }
  ]
}
