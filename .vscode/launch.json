{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "BengiDevTools (dotnet run)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/BengiDevTools/BengiDevTools.csproj",
      "launchSettingsProfile": "http",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "preLaunchTask": "build"
    },
    {
      "name": "Attach (välj process)",
      "type": "dotnet",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "justMyCode": false,
      "enableStepFiltering": false,
      "symbolOptions": {
        "searchPaths": [],
        "searchMicrosoftSymbolServer": false,
        "searchNuGetOrgSymbolServer": false
      }
    }
  ]
}
