{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug (Windows)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/BengiDevTools/BengiDevTools.csproj",
      "targetFramework": "net10.0-windows10.0.19041.0",
      "launchSettingsProfile": null,
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "preLaunchTask": "build"
    },
    {
      "name": "Run (dotnet run)",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/BengiDevTools/BengiDevTools.csproj",
        "--framework",
        "net10.0-windows10.0.19041.0"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "build"
    }
  ]
}
