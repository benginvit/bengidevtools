{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "BengiDevTools (dotnet run)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build BengiDevTools",
      "program": "${workspaceFolder}/BengiDevTools/bin/Debug/net10.0/BengiDevTools.dll",
      "cwd": "${workspaceFolder}/BengiDevTools",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openSimpleBrowser",
        "pattern": "Now listening on: (https?://\\S+)",
        "uriFormat": "%s"
      }
    }
  ]
}
